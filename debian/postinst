#!/bin/sh
set -e

case "$1" in
    configure)
        # Create system user and group if they don't exist
        if ! getent group debswarm > /dev/null 2>&1; then
            addgroup --system debswarm
        fi
        if ! getent passwd debswarm > /dev/null 2>&1; then
            adduser --system --ingroup debswarm --home /var/lib/debswarm \
                --no-create-home --disabled-password debswarm
        fi

        # Create and set ownership of directories
        mkdir -p /var/cache/debswarm /var/lib/debswarm /etc/debswarm
        chown -R debswarm:debswarm /var/cache/debswarm /var/lib/debswarm
        chmod 750 /var/cache/debswarm /var/lib/debswarm

        # The default configuration ships as a dpkg conffile
        # (packaging/config.system.toml, installed to /etc/debswarm/config.toml
        # by debian/rules), so dpkg places and manages it. Do not write it here:
        # a second source of truth drifts from the packaged config and can
        # conflict with dpkg's conffile handling on upgrade.
        ;;
esac

#DEBHELPER#

exit 0
